# Used by docker-compose. The JWT signing secret is shared across services so each
# one can verify tokens the Auth service issued.
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=1d
# The admin seed runs only when SEED_ADMIN_PASSWORD is set (no default is shipped).
SEED_ADMIN_EMAIL=admin@ascent.local
SEED_ADMIN_PASSWORD=
