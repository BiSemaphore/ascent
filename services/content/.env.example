# Copy to .env and fill in real values.
PORT=3002
DATABASE_URL=postgres://content:content@localhost:5434/content
# Must match the Auth service's JWT_SECRET so this service can verify its tokens.
JWT_SECRET=must-match-auth-service-secret
# Comma-separated Kafka brokers. Host tools use localhost:29092; in compose use kafka:9092.
KAFKA_BROKERS=localhost:29092
