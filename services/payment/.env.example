# Copy to .env and fill in real values.
PORT=3005
DATABASE_URL=postgres://payment:payment@localhost:5437/payment
# Must match the Auth service's JWT_SECRET so this service can verify its tokens.
JWT_SECRET=must-match-auth-service-secret
# Comma-separated Kafka brokers. Host tools use localhost:29092; in compose use kafka:9092.
KAFKA_BROKERS=localhost:29092
# Where to read cohort price/title from (in compose use http://cohort:3003).
COHORT_URL=http://localhost:3003
# App base URL for Stripe success/cancel redirects.
PUBLIC_URL=http://localhost:4200
# Stripe TEST-mode keys. Get them from your Stripe dashboard (test mode) and, for the
# webhook secret, from `stripe listen`. Never use live keys here.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
